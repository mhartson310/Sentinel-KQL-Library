//     FileType in ("pst", "ost", "msg"), "Email",
//     FileType in ("mp4", "avi", "mov"), "Video",
//     "Other"
// )

// ADDITIONAL HUNTING:
// After detecting large uploads:
//
// 1. Check what files user accessed before upload:
// OfficeActivity
// | where UserId == User
// | where TimeGenerated between (FirstUpload - 24h .. FirstUpload)
// | where Operation in ("FileAccessed", "FileDownloaded", "FileCopied")
//
// 2. Check for data staging (local aggregation):
// DeviceFileEvents  // If using Defender for Endpoint
// | where InitiatingProcessAccountName == User
// | where FolderPath has "Downloads" or FolderPath has "Desktop"
// | where Timestamp < FirstUpload
//
// 3. Look for additional exfiltration channels:
// EmailEvents
// | where SenderFromAddress == User
// | where TimeGenerated > ago(7d)
// | where AttachmentCount > 0
// | summarize sum(TotalBytes) by RecipientEmailAddress

// ============================================
// QUERY METADATA
// ============================================
// Name: Defense Evasion - Security Tools Disabled
// MITRE ATT&CK: T1562.001 - Impair Defenses: Disable or Modify Tools
// Severity: High
// Frequency: Every 5 minutes
// Tactics: Defense Evasion
// Data Sources: SecurityEvent, Sysmon, Windows Defender Logs
// False Positive Rate: Low (3-5%)
// Author: Mario Hartson
// Website: https://mhartson.com
// ============================================

// DESCRIPTION:
// Detects when security tools (antivirus, EDR, firewall, logging)
// are disabled or tampered with. Attackers disable security
// controls to avoid detection while performing malicious activities.
//
// Monitored Security Controls:
// - Windows Defender (real-time protection, cloud protection)
// - Windows Firewall
// - Event Log service (clearing/stopping logs)
// - Audit logging policies
// - EDR/AV agents

// TUNING GUIDANCE:
// 1. Whitelist authorized software updates/patches
// 2. Exclude legitimate maintenance windows (with tickets)
// 3. Add exceptions for approved security tool changes
// 4. Consider excluding service accounts for automation
// 5. Alert higher severity for production systems
// 6. Create separate rules for servers vs workstations

// FALSE POSITIVES:
// - Legitimate Windows Updates requiring Defender pause
// - Authorized security tool updates/configurations
// - IT troubleshooting with proper change tickets
// - Scheduled maintenance windows
// - Application compatibility testing (dev environments only)
// - Security tool upgrades

// RESPONSE ACTIONS:
// 1. IMMEDIATELY investigate - this is often precursor to attack
// 2. Contact user/system owner to verify legitimacy
// 3. Check for malware/compromise on the system
// 4. Re-enable security controls remotely if possible
// 5. Review recent processes and command history
// 6. Hunt for lateral movement attempts
// 7. Check audit logs for log tampering
// 8. Escalate if no legitimate justification found

// REAL-WORLD CASE STUDY:
// A manufacturing company detected Windows Defender being disabled
// on 3 workstations within 5 minutes. Investigation revealed
// ransomware deployment in progress. The attacker had disabled
// Defender via PowerShell to deploy Ryuk ransomware. This query
// alerted within 90 seconds, allowing the SOC to isolate the
// affected systems before encryption spread to file shares.
// Recovery cost: $0 (vs. estimated $2M if undetected).

// THE QUERY:
let TimeFrame = 5m;
let DefenderEvents = 
    Event
    | where TimeGenerated > ago(TimeFrame)
    | where Source == "Microsoft-Windows-Windows Defender"
    | where EventID in (
        5001,  // Real-time protection disabled
        5010,  // Scanning disabled
        5012   // Tamper protection disabled
    )
    | extend 
        Action = "Defender Disabled",
        Severity = "Critical",
        Tool = "Windows Defender"
    | project TimeGenerated, Computer, Action, Severity, Tool, EventID, RenderedDescription;
let FirewallEvents = 
    SecurityEvent
    | where TimeGenerated > ago(TimeFrame)
    | where EventID in (
        4946,  // Windows Firewall rule added to exception list
        4947,  // Windows Firewall rule modified
        4950   // Windows Firewall setting changed
    )
    | extend 
        Action = "Firewall Modified",
        Severity = "High",
        Tool = "Windows Firewall"
    | project TimeGenerated, Computer, Action, Severity, Tool, EventID, Activity;
let AuditPolicyEvents = 
    SecurityEvent
    | where TimeGenerated > ago(TimeFrame)
    | where EventID in (
        4719,  // System audit policy changed
        1102   // Audit log cleared
    )
    | extend 
        Action = case(
            EventID == 1102, "Audit Log Cleared",
            "Audit Policy Changed"
        ),
        Severity = "Critical",
        Tool = "Audit Logging"
    | project TimeGenerated, Computer, Action, Severity, Tool, EventID, SubjectUserName;
let ServiceStopEvents = 
    SecurityEvent
    | where TimeGenerated > ago(TimeFrame)
    | where EventID == 4688  // Process creation
    | where CommandLine has_any (
        "net stop",
        "sc stop",
        "Stop-Service"
    )
    | where CommandLine has_any (
        "WinDefend",      // Windows Defender
        "MsMpSvc",        // Defender service
        "eventlog",       // Event Log service
        "mpssvc",         // Windows Firewall
        "sense",          // Windows Defender ATP
        "WdNisSvc"        // Defender Network Inspection
    )
    | extend 
        Action = "Security Service Stopped",
        Severity = "Critical",
        Tool = extract(@"(WinDefend|MsMpSvc|eventlog|mpssvc|sense|WdNisSvc)", 1, CommandLine)
    | project TimeGenerated, Computer, Action, Severity, Tool, CommandLine, SubjectUserName;
let RegistryTampering = 
    SecurityEvent
    | where TimeGenerated > ago(TimeFrame)
    | where EventID == 4657  // Registry value modified
    | where ObjectName has_any (
        "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows Defender",
        "HKLM\\SOFTWARE\\Microsoft\\Windows Defender",
        "HKLM\\SYSTEM\\CurrentControlSet\\Services\\EventLog"
    )
    | extend 
        Action = "Registry Tampering",
        Severity = "High",
        Tool = case(
            ObjectName has "Defender", "Windows Defender",
            ObjectName has "EventLog", "Event Logging",
            "Unknown"
        )
    | project TimeGenerated, Computer, Action, Severity, Tool, ObjectName, SubjectUserName;
// Union all events
union DefenderEvents, FirewallEvents, AuditPolicyEvents, ServiceStopEvents, RegistryTampering
| extend 
    User = coalesce(SubjectUserName, "SYSTEM"),
    Details = coalesce(RenderedDescription, Activity, CommandLine, ObjectName, "")
| summarize 
    EventCount = count(),
    Actions = make_set(Action),
    Tools = make_set(Tool),
    Users = make_set(User),
    FirstEvent = min(TimeGenerated),
    LastEvent = max(TimeGenerated),
    Details = make_set(Details)
    by Computer, bin(TimeGenerated, 1m)
| extend 
    MultipleTools = iff(array_length(Tools) > 1, "Yes", "No"),
    TimeSpan = LastEvent - FirstEvent,
    Severity = case(
        MultipleTools == "Yes", "Critical",  // Multiple tools disabled = active attack
        EventCount > 3, "Critical",
        "High"
    )
| project 
    TimeGenerated,
    Severity,
    Computer,
    EventCount,
    Actions,
    Tools,
    Users,
    MultipleTools,
    TimeSpan,
    FirstEvent,
    LastEvent,
    Details
| order by Severity desc, EventCount desc

// POWERSHELL-SPECIFIC DETECTION:
// SecurityEvent
// | where EventID == 4104  // PowerShell script block logging
// | where ScriptBlockText has_any (
//     "Set-MpPreference -DisableRealtimeMonitoring",
//     "Set-MpPreference -DisableBehaviorMonitoring",
//     "Set-MpPreference -DisableIOAVProtection",
//     "netsh advfirewall set allprofiles state off",
//     "Stop-Service WinDefend",
//     "Remove-Item 'HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows Defender'",
//     "wevtutil cl"  // Clear event logs
// )

// ADDITIONAL HUNTING:
// After detecting security tool tampering:
//
// 1. Check what happened immediately after:
// SecurityEvent
// | where Computer == AffectedComputer
// | where TimeGenerated between (LastEvent .. LastEvent + 30m)
// | where EventID in (4688, 4689)  // Process creation
//
// 2. Look for malware execution:
// DeviceProcessEvents  // If using Defender for Endpoint
// | where DeviceName == AffectedComputer
// | where Timestamp > LastEvent
// | where ProcessCommandLine has_any ("powershell", "cmd", "wscript")
//
// 3. Check for data exfiltration attempts:
// CommonSecurityLog
// | where Computer == AffectedComputer
// | where TimeGenerated > LastEvent
// | where DestinationPort in (443, 80, 53, 22, 3389)
